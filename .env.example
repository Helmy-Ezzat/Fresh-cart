# API Configuration
REACT_APP_API_BASE_URL=https://ecommerce.routemisr.com/api/v1

# App Configuration
REACT_APP_NAME=FreshCart
REACT_APP_VERSION=1.0.0

# Payment Configuration (for checkout redirect)
REACT_APP_PAYMENT_REDIRECT_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Optional: Analytics
# REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Optional: Error Tracking
# REACT_APP_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Optional: Feature Flags
REACT_APP_ENABLE_DEVTOOLS=true
REACT_APP_ENABLE_OFFLINE_MODE=false
