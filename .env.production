# API Configuration
REACT_APP_API_BASE_URL=https://ecommerce.routemisr.com/api/v1

# App Configuration
REACT_APP_NAME=FreshCart
REACT_APP_VERSION=1.0.0

# Payment Configuration (for checkout redirect)
# Update this with your production URL
REACT_APP_PAYMENT_REDIRECT_URL=https://your-domain.com

# Environment
NODE_ENV=production

# Feature Flags
REACT_APP_ENABLE_DEVTOOLS=false
REACT_APP_ENABLE_OFFLINE_MODE=false
